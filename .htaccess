# Apache is pointed at the project root (e.g. http://127.0.0.1/greta_crashfix/).
# This project runs Yii1 from root index.php.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /greta_crashfix/

    # Normalize legacy Yii2-style URLs to Yii1 root URLs.
    RewriteRule ^web$ /greta_crashfix/ [R=302,L]
    RewriteRule ^web/(.*)$ /greta_crashfix/$1 [R=302,L]

    # Directory /greta_crashfix/ — route explicitly to Yii1 front controller.
    RewriteRule ^$ index.php [L]

    # Existing files under the repo are served directly.
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Pretty URLs: everything else goes to Yii1.
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . index.php [L]
</IfModule>
